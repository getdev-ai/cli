{
  "name": "drizzle-orm",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": { "types": "./index.d.ts", "default": "./index.js" },
      "default": "./index.js",
      "require": { "types": "./index.d.cts", "default": "./index.cjs" }
    },
    "./pg-core": {
      "types": "./pg-core/index.d.ts",
      "import": { "types": "./pg-core/index.d.ts", "default": "./pg-core/index.js" },
      "default": "./pg-core/index.js",
      "require": { "types": "./pg-core/index.d.cts", "default": "./pg-core/index.cjs" }
    }
  }
}
